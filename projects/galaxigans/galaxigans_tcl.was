; galaxigans_tcl.was — nano-TCL state exposure + dev/test verbs. Registered in GameInit;
; ExposeState publishes game state into the introspector ping each frame. (.CODE + .DATA)
;
; Slots (read with `lindex [regs] N`): 0 score, 1 bossState, 2 abducting, 3 lives, 4 gameState.

module Galaxigans
.DATA
.balign 8
vnPlayNow  BYTE "playnow", 0
vnBossArm  BYTE "bossarm", 0
vnHitBoss  BYTE "hitboss", 0
vnCapLast  BYTE "caplast", 0
vnCapKeep  BYTE "capkeep", 0
vnCapNone  BYTE "capnone", 0
.balign 16

.CODE

; ---- ExposeState: publish state into the introspector ping (TclReg slots) ----
proc ExposeState frame
    xor     ecx, ecx
    mov     edx, [rip + score]
    call    TclReg
    mov     ecx, 1
    mov     edx, [rip + bossState]
    call    TclReg
    mov     ecx, 2
    mov     edx, [rip + abducting]
    call    TclReg
    mov     ecx, 3
    mov     edx, [rip + lives]
    call    TclReg
    mov     ecx, 4
    mov     edx, [rip + gameState]
    call    TclReg
    mov     ecx, 5
    mov     edx, [rip + bossY]
    call    TclReg
endproc

; ---- RegisterTclVerbs: add the game's dev/test verbs (called from GameInit) ----
proc RegisterTclVerbs frame
    lea     rcx, [rip + vnPlayNow]
    lea     rdx, [rip + PlayNowVerb]
    call    TclAddVerb
    lea     rcx, [rip + vnBossArm]
    lea     rdx, [rip + BossArmVerb]
    call    TclAddVerb
    lea     rcx, [rip + vnHitBoss]
    lea     rdx, [rip + HitBossVerb]
    call    TclAddVerb
    lea     rcx, [rip + vnCapLast]
    lea     rdx, [rip + CapLastVerb]
    call    TclAddVerb
    lea     rcx, [rip + vnCapKeep]
    lea     rdx, [rip + CapKeepVerb]
    call    TclAddVerb
    lea     rcx, [rip + vnCapNone]
    lea     rdx, [rip + CapNoneVerb]
    call    TclAddVerb
endproc

; ---- playnow — jump straight into a fresh PLAYING game (skip the title) ----
proc PlayNowVerb frame
    call    NewGame
    mov     dword ptr [rip + gameState], STATE_PLAYING
endproc

; ---- bossarm — force the boss into BEAM with a pilot mid-abduction (test setup) ----
proc BossArmVerb frame
    mov     dword ptr [rip + bossState], BS_BEAM
    mov     dword ptr [rip + bossX], 304
    mov     dword ptr [rip + bossY], BOSS_CAP_Y
    mov     dword ptr [rip + bossBeamT], 0
    mov     dword ptr [rip + abducting], 1
    mov     eax, [rip + bossX]
    add     eax, 10
    mov     [rip + abducteeX], eax
    mov     dword ptr [rip + abducteeY], 220   ; a pilot partway up the beam
endproc

; ---- hitboss — drop a player bullet inside the boss box (so CheckBossHit fires next frame) ----
proc HitBossVerb frame
    lea     r8, [rip + bullets]
    mov     eax, [rip + bossX]
    add     eax, 16
    mov     [r8 + 0], eax
    mov     eax, [rip + bossY]
    add     eax, 16
    mov     [r8 + 4], eax
    mov     dword ptr [r8 + 8], 1
    mov     dword ptr [r8 + 12], 0
endproc

; ---- bossCapArm — boss in BEAM with a pilot ~2 ticks from being taken (shared test setup) ----
proc bossCapArm frame
    mov     dword ptr [rip + bossState], BS_BEAM
    mov     dword ptr [rip + bossX], 304
    mov     dword ptr [rip + bossY], BOSS_CAP_Y
    mov     dword ptr [rip + bossBeamT], 0
    mov     dword ptr [rip + abducting], 1
    mov     eax, [rip + bossX]
    add     eax, 10
    mov     [rip + abducteeX], eax
    mov     dword ptr [rip + abducteeY], BOSS_CAP_Y + 32   ; rises to <= bossY+26 within ~2 frames
endproc

; ---- caplast — lives=1, so the next abduction is the last pilot (must end the game) ----
proc CapLastVerb frame
    mov     dword ptr [rip + lives], 1
    call    bossCapArm
endproc

; ---- capkeep — lives=3, a non-final abduction (the boss should take one + retreat off-screen) ----
proc CapKeepVerb frame
    mov     dword ptr [rip + lives], 3
    call    bossCapArm
endproc

; ---- capnone — lives=1, beam on but NO grab started: the boss must not take the last pilot ----
proc CapNoneVerb frame
    mov     dword ptr [rip + lives], 1
    mov     dword ptr [rip + bossState], BS_BEAM
    mov     dword ptr [rip + bossX], 304
    mov     dword ptr [rip + bossY], BOSS_CAP_Y
    mov     dword ptr [rip + bossBeamT], 0
    mov     dword ptr [rip + abducting], 0
endproc

endmodule
