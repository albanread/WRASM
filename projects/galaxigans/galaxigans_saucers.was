; -------------------------------------------------------------------------------------
; SAUCER 3 — "OBSIDIAN DREADNOUGHT"  (LEVEL 3) : heaviest, most ornate capital ship.
;   A long armoured wedge with layered green hull plating, a forward command spike, twin
;   spinal cannons, a row of viewport lights, and a quad-engine bank that pulses. Frame
;   anim = the engine bank flares (red->white) + the cannon charge glow + viewport blink.
;   Palette:
;     0 transparent
;     1 0x00040A06  dark outline
;     2 0x000F2A18  hull shadow (deep jade)
;     3 0x00184A28  hull mid-dark
;     4 0x00266A38  hull mid (jade)
;     5 0x00389A50  hull light
;     6 0x0058C878  hull highlight (acid green edge)
;     7 0x00A8F0B0  plating sheen / bevel
;     8 0x00C0C0C0  steel cannon / spike (silver)
;     9 0x00FFF0A0  viewport light (pale gold)
;     A 0x00FF3020  engine flame core (red) — low pulse
;     B 0x00FF9A20  engine flame mid (orange)
;     C 0x00FFE060  engine flame hot (yellow) — high pulse
;     D 0x00FFFFFF  spark / cannon charge glint
;     E 0x009030C0  energy halo (violet) — cannon charge ring
;     F 0x0040FFE0  forward sensor beam (cyan)
; -------------------------------------------------------------------------------------
.balign 16
; frame 0 — engines low (A/B) at LEFT, cannons charged (E ring + D glint), viewports LIT (9).
;           Command spike + cyan sensor beam (F) point RIGHT.
saucer3Art   BYTE "..............8F8..............."
             BYTE "..............888....1111111...."
             BYTE "..AB.......111887711177666667111"
             BYTE ".AABB...11776655555776655555671."
             BYTE "AAABB117766554444446654444446671"
